@prefix 革命文物: <http://www.owl-ontologies.com/RevolutionaryRelics.owl#>.@include <RDFS>.@include <OWL>.

# 北京市革命文物推理规则
# 定义文物与批次、地点、人物之间的反向关系

[Rule1: (?a 革命文物:属于批次 ?b) -> (?b 革命文物:包含文物 ?a)]
[Rule2: (?a 革命文物:所在地 ?b) -> (?b 革命文物:位于区域 ?a)]
[Rule3: (?a 革命文物:相关人物 ?b) -> (?b 革命文物:人物相关文物 ?a)]
[Rule4: (?a 革命文物:位于片区 ?b) -> (?b 革命文物:片区包含文物 ?a)]
[Rule5: (?a 革命文物:所属时期 ?b) -> (?b 革命文物:时期包含文物 ?a)]
[Rule6: (?a 革命文物:文物级别 ?b) -> (?b 革命文物:级别包含文物 ?a)]

# 同一区域内文物的关联关系
[Rule7: (?a 革命文物:所在地 ?c), (?b 革命文物:所在地 ?c), notEqual(?a, ?b) -> (?a 革命文物:同城文物 ?b)]

# 同一批次内文物的关联关系
[Rule8: (?a 革命文物:属于批次 ?c), (?b 革命文物:属于批次 ?c), notEqual(?a, ?b) -> (?a 革命文物:同批次文物 ?b)]

# 同一主题片区内文物的关联关系
[Rule9: (?a 革命文物:位于片区 ?c), (?b 革命文物:位于片区 ?c), notEqual(?a, ?b) -> (?a 革命文物:同片区文物 ?b)]

# 同一历史时期文物的关联关系
[Rule10: (?a 革命文物:所属时期 ?c), (?b 革命文物:所属时期 ?c), notEqual(?a, ?b) -> (?a 革命文物:同时期文物 ?b)]

# 相关人物之间的关联
[Rule11: (?a 革命文物:相关人物 ?c), (?b 革命文物:相关人物 ?c), notEqual(?a, ?b) -> (?a 革命文物:相关人物相同 ?b)]
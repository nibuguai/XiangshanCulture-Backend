<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:革命文物="http://www.owl-ontologies.com/RevolutionaryRelics.owl#"
    xmlns="http://www.owl-ontologies.com/BeijingRevolution.owl#"
  xml:base="http://www.owl-ontologies.com/culture.owl">
  
  <owl:Ontology rdf:about=""/>
  
  <!-- ==================== 顶层类定义 ==================== -->
  
  <!-- 革命文物主类 -->
  <owl:Class rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">革命文物</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">北京市革命文物，包括第一批和第二批名录中的文物</rdfs:comment>
  </owl:Class>
  
  <!-- 不可移动革命文物 -->
  <owl:Class rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#不可移动文物">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">不可移动文物</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物"/>
  </owl:Class>
  
  <!-- 可移动革命文物 -->
  <owl:Class rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#可移动文物">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">可移动文物</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物"/>
  </owl:Class>
  
  <!-- ==================== 不可移动文物子类 ==================== -->
  
  <owl:Class rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#重要机构驻地">

  <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#属于批次">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">属于批次</rdfs:label>
    <rdfs:domain rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物"/>
    <rdfs:range rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#批次"/>
  </owl:ObjectProperty>
  
  <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#文物级别">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">文物级别</rdfs:label>
    <rdfs:domain rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物"/>
    <rdfs:range rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#文物级别"/>
  </owl:ObjectProperty>
  
  <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#所在地">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">所在地</rdfs:label>
    <rdfs:domain rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物"/>
    <rdfs:range rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#地点"/>
  </owl:ObjectProperty>
  
  <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#所属时期">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">所属时期</rdfs:label>
    <rdfs:domain rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物"/>
    <rdfs:range rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#历史时期"/>
  </owl:ObjectProperty>
  
  <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#相关人物">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">相关人物</rdfs:label>
    <rdfs:domain rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物"/>
    <rdfs:range rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#相关人物"/>
  </owl:ObjectProperty>
  
  <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#位于片区">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">位于片区</rdfs:label>
    <rdfs:domain rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物"/>
    <rdfs:range rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#主题片区"/>
  </owl:ObjectProperty>
  
  <!-- 反向属性 -->
  <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#包含文物">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">包含文物</rdfs:label>
    <owl:inverseOf rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#属于批次"/>
  </owl:ObjectProperty>
  
  <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#人物相关文物">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">人物相关文物</rdfs:label>
    <owl:inverseOf rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#相关人物"/>
  </owl:ObjectProperty>
  
  <!-- 数据属性 -->
  <owl:DatatypeProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#文物名称">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">文物名称</rdfs:label>
    <rdfs:domain rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#革命文物"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  
  <owl:DatatypeProperty rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#文物简介">

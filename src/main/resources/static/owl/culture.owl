  <!-- ==================== 北京香山红色文化实例 ==================== -->

  <!-- 时间点实例：1949年 -->
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#1949年">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#时间点"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1949年</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">中共中央进驻香山的重要年份</rdfs:comment>
  </owl:NamedIndividual>

  <!-- 1949年3月25日：毛泽东同志率领中共中央和中国人民解放军总部进驻北京香山 -->
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#1949年3月25日进驻香山">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#历史事件"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1949年3月25日：毛泽东同志率领中共中央和中国人民解放军总部进驻北京香山</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1949年3月25日，毛泽东同志率领中共中央和中国人民解放军总部进驻北京香山，标志着中国革命重心从农村转向城市</rdfs:comment>
  </owl:NamedIndividual>

  <!-- 1949年6月19日：毛泽东同志写给宋庆龄的亲笔信 -->
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#毛泽东致宋庆龄信">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#相关遗物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1949年6月19日：毛泽东同志写给宋庆龄的亲笔信</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">庆龄先生：重庆违教，忽近四年。仰望之诚，与日俱积。兹者全国革命胜利在即，建设大计，亟待商筹，特派邓颖超同志趋前致候，专诚欢迎先生北上。敬希命驾莅平，以便就近请教，至祈勿却为盼！专此敬颂大安！毛泽东 一九四九年六月十九日</rdfs:comment>
  </owl:NamedIndividual>

  <!-- 1949年6月21日：周恩来同志写给宋庆龄的亲笔信 -->
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#周恩来致宋庆龄信">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#相关遗物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1949年6月21日：周恩来同志写给宋庆龄的亲笔信</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">庆龄先生：沪滨告别，瞬近三年。每当蒋贼肆虐之际，辄以先生安全为念。今幸解放迅速，先生从此永脱险境，诚人民之大喜，私心亦为之大慰。现全国胜利在即，新中国建设有待于先生指教者正多。敢藉颖超专诚迎迓之便，谨陈渴望先生北上之情。敬希早日命驾，实为至幸。耑上。敬颂大安 周恩来 一九四九.六.廿一</rdfs:comment>
  </owl:NamedIndividual>

  <!-- 相关遗址实例 -->
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#香山公园">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#相关遗址"/>
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#相关遗物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山公园</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山公园位于北京市海淀区，是一座具有山林特色的皇家园林，也是中共中央进京后的驻地。双清别墅和来青轩等革命旧址位于园内，是重要的红色文化遗址。</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#香山革命纪念地">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#相关遗址"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山革命纪念地</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山革命纪念地包括双清别墅、来青轩等多处革命旧址，是1949年中共中央所在地，见证了中国革命走向全国胜利的伟大历程。</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#香山故居">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#相关遗址"/>
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#相关遗物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山故居</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山故居是中共中央领导人在香山期间的居住地，包括双清别墅、来青轩等多处革命旧址，见证了中国革命走向全国胜利的伟大历程。</rdfs:comment>
  </owl:NamedIndividual>

  <!-- 相关遗物实例 -->
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#双清别墅毛泽东办公旧址">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#相关遗物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">双清别墅毛泽东办公旧址</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">毛泽东同志在双清别墅工作和生活的地方，见证了渡江战役指挥、南京解放等重大历史事件。</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#来青轩周恩来办公旧址">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#相关遗物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">来青轩周恩来办公旧址</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">周恩来同志在来青轩工作和生活的地方，参与筹建新中国各项重要工作。</rdfs:comment>
  </owl:NamedIndividual>

  <!-- 建筑建造实例 -->
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#香山革命纪念馆">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#建筑建造"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山革命纪念馆</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山革命纪念馆是为纪念中共中央在香山时期的革命历史而建设的专题纪念馆，展示了"为新中国奠基——中共中央在香山"主题展览。</rdfs:comment>
  </owl:NamedIndividual>

  <!-- 自然遗存实例 -->
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#香山自然景观">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#自然遗存"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山自然景观</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">香山自然景观包括香山的红叶、古树、山泉等自然景观，是香山公园的重要组成部分，也是红色文化的重要载体。</rdfs:comment>
  </owl:NamedIndividual>

  <!-- 相关人物实例 -->
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#毛泽东_香山">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#人物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">毛泽东</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">中国共产党、中国人民解放军和中华人民共和国的主要缔造者，1949年在香山指挥渡江战役，筹备新政协会议，筹建新中国。</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#周恩来_香山">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#人物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">周恩来</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">伟大的无产阶级革命家，在香山期间参与筹建新中国各项重要工作，写信邀请宋庆龄北上参加新政协会议。</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#宋庆龄">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#人物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">宋庆龄</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">伟大的爱国主义、民主主义、国际主义和共产主义战士，收到毛泽东、周恩来亲笔信后北上参加新政协会议。</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/BeijingRevolution.owl#邓颖超">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/BeijingRevolution.owl#人物"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">邓颖超</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">伟大的无产阶级革命家，受毛泽东委托前往上海迎接宋庆龄北上。</rdfs:comment>
  </owl:NamedIndividual>


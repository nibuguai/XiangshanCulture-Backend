  </owl:Class>
  
  <owl:Class rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#手稿信件">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">手稿信件</rdfs:label>

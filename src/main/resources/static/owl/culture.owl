  <!-- ==================== 实例：批次 ==================== -->
  
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#第一批">
    <rdf:type rdf:resource="http://www.owl-ontologies.com/RevolutionaryRelics.owl#批次"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">第一批</rdfs:label>
    <革命文物:文物简介 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">北京市第一批革命文物名录，包括158处不可移动革命文物和2111件/套可移动革命文物</革命文物:文物简介>
  </owl:NamedIndividual>
  
  <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/RevolutionaryRelics.owl#第二批">
